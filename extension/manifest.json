{
  "manifest_version": 3,
  "name": "Deutschway",
  "version": "1.1",
  "description": "Learn 5 German words daily. Extension companion for Deutschway.",
  "permissions": [
    "storage"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://officiallygod.github.io/*"],
      "js": ["content.js"]
    }
  ],
  "action": {
    "default_title": "Open Deutschway",
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
