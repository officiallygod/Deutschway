{
  "manifest_version": 3,
  "name": "Deutschway",
  "version": "1.0",
  "description": "Learn 5 German words daily when you open Chrome.",
  "permissions": [
    "storage",
    "tabs"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Open Deutschway"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
